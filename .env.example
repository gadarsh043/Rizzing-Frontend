# Frontend Environment Variables
# Copy this file to .env and fill in the values below

# The URL where the backend express server is running
# In development, it's usually http://localhost:3000
VITE_API_URL="http://localhost:3000"

# Firebase Client Configuration (Needed for Phase 2)
# You get these from your Firebase Project Settings -> General -> Web App
VITE_FIREBASE_API_KEY="your_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"
VITE_FIREBASE_APP_ID="your_app_id"
